# Exemple de configuration backend MedWork - copier en .env et remplir

# Connexion PostgreSQL Supabase (Session pooler, port 5432)
DATABASE_URL="postgresql://postgres.xxxx:MOT_DE_PASSE@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# Secret de signature des tokens JWT (genere automatiquement par Render en prod)
JWT_SECRET="changez-moi-en-production"
JWT_EXPIRES_IN="8h"

# Port du serveur (Render fournit PORT automatiquement)
PORT=3001

NODE_ENV=development

# Domaines frontend autorises (CORS), separes par des virgules
# ex: https://medwork.vercel.app,https://app.medwork.com
CORS_ORIGINS=""
